{
  "catalog_version": "evidenceops-public-values-v1.0.0",
  "patterns": [
    {
      "label": "email address",
      "expression": "\\b[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}\\b",
      "flags": "i"
    },
    {
      "label": "IP address",
      "expression": "(?<![\\d.])(?:25[0-5]|2[0-4]\\d|1?\\d?\\d)(?:\\.(?:25[0-5]|2[0-4]\\d|1?\\d?\\d)){3}(?![\\d.])",
      "flags": ""
    },
    {
      "label": "UUID-like identifier",
      "expression": "\\b[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12}\\b",
      "flags": "i"
    },
    {
      "label": "raw fixture marker",
      "expression": "RAW_FIXTURE_MARKER",
      "flags": ""
    },
    {
      "label": "serial-like value",
      "expression": "\\b(?:SERIAL|S/N|SN)[-: ]?[A-Z0-9]{6,}\\b",
      "flags": "i"
    },
    {
      "label": "domain name",
      "expression": "\\b(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+[a-z]{2,63}\\b",
      "flags": "i"
    }
  ]
}
