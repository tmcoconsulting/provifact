{
  "catalog_version": "evidenceops-credentials-v1.0.0",
  "patterns": [
    {
      "label": "private key",
      "expression": "-----BEGIN (?:RSA |EC |OPENSSH )?PRIVATE KEY-----",
      "flags": ""
    },
    {
      "label": "certificate material",
      "expression": "-----BEGIN CERTIFICAT[E]-----",
      "flags": ""
    },
    {
      "label": "GitHub token",
      "expression": "\\b(?:gh[pousr]_[A-Za-z0-9]{30,}|github_pat_[A-Za-z0-9_]{30,})\\b",
      "flags": ""
    },
    {
      "label": "Slack token",
      "expression": "\\bxox[baprs]-[A-Za-z0-9-]{20,}\\b",
      "flags": ""
    },
    {
      "label": "OpenAI API key",
      "expression": "\\bsk-[A-Za-z0-9_-]{20,}\\b",
      "flags": ""
    },
    {
      "label": "JWT-like access token",
      "expression": "\\beyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\b",
      "flags": ""
    },
    {
      "label": "bearer credential",
      "expression": "\\b(?:authorization\\s*[:=]\\s*)?Bearer\\s+[A-Za-z0-9._~+/-]{20,}=*",
      "flags": "i"
    }
  ]
}
