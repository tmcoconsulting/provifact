{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "evidenceops-fixture",
  "main": "worker/src/index.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
  "workers_dev": false,
  "send_metrics": false,
  "assets": {
    "directory": "./site",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page",
    "run_worker_first": ["/api/*"],
  },
  "vars": {
    "EVIDENCEOPS_MODE": "fixture",
    "OPENAI_MODEL": "gpt-5.6-terra",
  },
  "ratelimits": [
    {
      "name": "NARRATIVE_RATE_LIMITER",
      "namespace_id": "11001",
      "simple": {
        "limit": 3,
        "period": 60,
      },
    },
    {
      "name": "NARRATIVE_GLOBAL_RATE_LIMITER",
      "namespace_id": "11002",
      "simple": {
        "limit": 30,
        "period": 60,
      },
    },
  ],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "invocation_logs": false,
      "persist": true,
    },
    "traces": {
      "enabled": false,
      "persist": false,
    },
  },
  "env": {
    "preview": {
      "name": "evidenceops-preview",
      "workers_dev": true,
      "preview_urls": true,
      "vars": {
        "EVIDENCEOPS_MODE": "fixture",
        "OPENAI_MODEL": "gpt-5.6-terra",
      },
      "ratelimits": [
        {
          "name": "NARRATIVE_RATE_LIMITER",
          "namespace_id": "12001",
          "simple": {
            "limit": 3,
            "period": 60,
          },
        },
        {
          "name": "NARRATIVE_GLOBAL_RATE_LIMITER",
          "namespace_id": "12002",
          "simple": {
            "limit": 30,
            "period": 60,
          },
        },
      ],
    },
    "production": {
      "name": "evidenceops",
      "workers_dev": false,
      "routes": [
        {
          "pattern": "evidenceops.tmcoconsulting.com",
          "custom_domain": true,
        },
      ],
      "vars": {
        "EVIDENCEOPS_MODE": "fixture",
        "OPENAI_MODEL": "gpt-5.6-terra",
      },
      "secrets": {
        "required": ["OPENAI_API_KEY"],
      },
      "ratelimits": [
        {
          "name": "NARRATIVE_RATE_LIMITER",
          "namespace_id": "21001",
          "simple": {
            "limit": 3,
            "period": 60,
          },
        },
        {
          "name": "NARRATIVE_GLOBAL_RATE_LIMITER",
          "namespace_id": "21002",
          "simple": {
            "limit": 30,
            "period": 60,
          },
        },
      ],
    },
  },
}
